Bootstrap: docker
From: nvcr.io/nvidia/pytorch:25.05-py3

%files
    # Copy project files during build
    pyproject.toml /app/pyproject.toml
    uv.lock /app/uv.lock

%post
    # Update and install basic utilities
    apt-get update && apt-get install -y \
        git \
        curl \
        wget \
        vim \
        build-essential \
        && rm -rf /var/lib/apt/lists/*

    # Install uv (Python package installer) system-wide
    curl -LsSf https://astral.sh/uv/install.sh | sh

    # Move uv to system-wide location so it's accessible regardless of user
    mv /root/.local/bin/uv /usr/local/bin/uv

    # Install Python dependencies
    cd /app
    uv sync --frozen

    # Create necessary directories
    mkdir -p /app/scripts
    mkdir -p /app/data
    mkdir -p /app/outputs
    mkdir -p /app/metrics
    mkdir -p /app/models

%environment
    export PYTHONUNBUFFERED=1

    # HuggingFace configuration
    export HF_HUB_ENABLE_HF_TRANSFER=1

    # Set default working directory
    export WORKDIR=/app

%runscript
    exec /bin/bash "$@"

%labels
    Author Lester James V. Miranda
    Version v0.1.0
    Description Multilingual Teacher Evaluation Project
    Base nvcr.io/nvidia/pytorch:25.05-py3

%help
    Multilingual Teacher Evaluation Project (mtep) - Singularity Container

    For usage instructions and examples, see:
    https://github.com/ljvmiranda921/multilingual-teacher-eval#running-on-isambard-using-singularity
