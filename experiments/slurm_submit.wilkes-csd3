#!/bin/bash
#SBATCH --account=KORHONEN-SL3-GPU
#SBATCH --job-name=csd3-job
#SBATCH --partition=ampere
#SBATCH --nodes=1
#SBATCH --gres=gpu:2
#SBATCH --output=gpu-%j.log
#SBATCH --time=10:00:00
#SBATCH --mail-type=NONE

# Generic SLURM submission wrapper for Wilkes-CSD3
# Usage: sbatch slurm_submit.wilkes-csd3 <job_script> [args...]
#
# Example:
#   sbatch slurm_submit.wilkes-csd3 jobs/create_synthetic_datasets.sh
#   sbatch slurm_submit.wilkes-csd3 jobs/get_intrinsic_metrics.sh
#   sbatch slurm_submit.wilkes-csd3 jobs/finetune_student_model_unsloth.sh
#
# Note: Adjust --array parameter manually in this script based on the job

# Module setup: cluster environment and recent python
. /etc/profile.d/modules.sh
module purge
module load rhel8/default-amp
module load python/3.11.9/gcc/abrhyqg7

# CSD3-specific cache exports
export HF_HOME=/home/ljvm2/rds/hpc-work/hpc_cache/huggingface
export HF_HUB_CACHE=/home/ljvm2/rds/hpc-work/hpc_cache/hf_hub
export VLLM_CACHE_ROOT=/home/ljvm2/rds/hpc-work/hpc_cache/vllm
export OMP_NUM_THREADS=16
export CUDA_VISIBLE_DEVICES=0,1

# Get job script from arguments
JOB_SCRIPT=$1
shift

if [ -z "$JOB_SCRIPT" ]; then
    echo "Error: No job script specified"
    echo "Usage: sbatch slurm_submit.wilkes-csd3 <job_script> [args...]"
    exit 1
fi

if [ ! -f "$JOB_SCRIPT" ]; then
    echo "Error: Job script '$JOB_SCRIPT' not found"
    exit 1
fi

# ====== Job info ======
JOBID=$SLURM_JOB_ID
numnodes=$SLURM_JOB_NUM_NODES
numtasks=$SLURM_NTASKS
mpi_tasks_per_node=$(echo "$SLURM_TASKS_PER_NODE" | sed -e  's/^\([0-9][0-9]*\).*$/\1/')

echo -e "JobID: $JOBID\n======"
echo "Time: `date`"
echo "Running on master node: `hostname`"
echo "Current directory: `pwd`"

if [ "$SLURM_JOB_NODELIST" ]; then
        #! Create a machine file:
        echo -e "\nNodes allocated:\n================"
        echo `cat machine.file.$JOBID | sed -e 's/\..*$//g'`
fi

echo -e "\nnumtasks=$numtasks, numnodes=$numnodes, mpi_tasks_per_node=$mpi_tasks_per_node (OMP_NUM_THREADS=$OMP_NUM_THREADS)"

# =========================

# Execute the job script with remaining arguments
bash "$JOB_SCRIPT" "$@"
